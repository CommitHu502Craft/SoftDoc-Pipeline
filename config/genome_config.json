  "narrative_styles": {
    "technical": {
      "description": "技术导向风格",
      "tone": "专业、精确、术语丰富",
      "sentence_structure": "简洁明了",
      "vocabulary_level": "专业术语",
      "suitable_for": ["技术文档", "API文档", "架构说明"]
    },
    "business": {
      "description": "商业导向风格",
      "tone": "正式、权威、价值导向",
      "sentence_structure": "条理清晰",
      "vocabulary_level": "商务用语",
      "suitable_for": ["商业计划", "产品说明", "用户手册"]
    },
    "tutorial": {
      "description": "教程导向风格",
      "tone": "友好、详细、循序渐进",
