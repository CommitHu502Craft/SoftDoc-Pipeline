{
  "languages": {
    "Java": {
      "framework": "Spring Boot",
      "file_ext": ".java",
      "comment_style": "javadoc",
      "version": "17+",
      "build_tool": "Maven",
      "package_prefix": "com.example"
    },
    "Go": {
      "framework": "Gin",
      "file_ext": ".go",
      "comment_style": "godoc",
      "version": "1.20+",
      "build_tool": "Go Modules",
      "package_prefix": "main"
    },
    "Python": {
      "framework": "FastAPI",
      "file_ext": ".py",
      "comment_style": "docstring",
      "version": "3.9+",
      "build_tool": "pip",
      "package_prefix": "app"
    },
    "Node.js": {
      "framework": "Express",
      "file_ext": ".js",
      "comment_style": "jsdoc",
      "version": "16+",
      "build_tool": "npm",
      "package_prefix": "src"
    },
    "PHP": {
      "framework": "Laravel",
      "file_ext": ".php",
      "comment_style": "phpdoc",
      "version": "8.1+",
      "build_tool": "Composer",
      "package_prefix": "App"
    }
  },

  "ui_frameworks": {
    "Tailwind": {
      "cdn_url": "https://cdn.tailwindcss.com",
      "class_prefix": "",
      "version": "3.3.0",
      "description": "实用优先的CSS框架",
      "features": ["响应式设计", "深色模式", "自定义主题"],
      "grid_system": "flex/grid"
    },
    "Bootstrap": {
      "cdn_url": "https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css",
      "class_prefix": "",
      "version": "5.3.0",
      "description": "流行的前端工具包",
      "features": ["组件丰富", "栅格系统", "响应式"],
      "grid_system": "12-column"
    }
  },

  "layout_modes": {
    "sidebar-left": {
      "description": "左侧边栏导航",
      "structure": "vertical-nav-left",
      "suitable_for": ["管理后台", "数据平台", "CMS系统"],
      "sidebar_width": "240px"
    },
    "sidebar-right": {
      "description": "右侧边栏导航",
      "structure": "vertical-nav-right",
      "suitable_for": ["内容展示", "文档系统", "阅读应用"],
      "sidebar_width": "260px"
    },
    "topbar": {
      "description": "顶部水平导航",
      "structure": "horizontal-nav-top",
      "suitable_for": ["企业官网", "营销页面", "门户网站"],
      "topbar_height": "60px"
    },
    "mixed": {
      "description": "顶部+左侧混合导航",
      "structure": "hybrid-nav",
      "suitable_for": ["大型系统", "多功能平台", "企业应用"],
      "topbar_height": "60px",
      "sidebar_width": "220px"
    }
  },

